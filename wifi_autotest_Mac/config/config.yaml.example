# ==============================================================================
#  config.yaml.example
#  ---------------------------------------------------------------------------
#  Copy this file to config.yaml and fill in your environment values.
#  DO NOT commit config.yaml to git (see .gitignore).
# ==============================================================================

# ----- Device Under Test (the WiFi router being tested) -----
dut:
  host: 192.168.99.1
  ssh_user: admin
  # Choose ONE authentication method:
  ssh_password: "CHANGEME"                  # plain password (simple but less secure)
  # ssh_key_path: ~/.ssh/id_rsa             # or use SSH key (recommended)

  # Serial console (on Test PC)
  # Linux:  /dev/ttyUSB0  (check with: dmesg | tail)
  # macOS:  /dev/tty.usbserial-XXXX or /dev/tty.SLAB_USBtoUART
  #         (check with: ls /dev/tty.usb* /dev/tty.SLAB_*)
  serial_port: /dev/ttyUSB0
  serial_baud: 115200

  # Wireless settings the test suite will configure
  wifi:
    ssid_2g: "TestBed-2G"
    ssid_5g: "TestBed-5G"
    ssid_6g: "TestBed-6G"
    psk:     "testbed12345"
    channel_2g: 6
    channel_5g: 36
    channel_6g: 37

# ----- Banana Pi BPI-R4 (WiFi STA client / traffic generator) -----
bpi_sta:
  host: 192.168.99.100
  ssh_user: root
  ssh_key_path: ~/.ssh/id_rsa
  # ssh_password: "bananapi"                # alternative

  # Wireless interfaces per band.
  # Standard Linux (ath9k/mac80211): wlan0 / wlan1 / wlan2
  # MediaTek BPI-R4: apcli0 / apclii0 / apclix0
  wifi_iface_2g: wlan0
  wifi_iface_5g: wlan1
  wifi_iface_6g: wlan2

# ----- Test Controller (this Test PC) -----
controller:
  log_dir: ./runs              # where per-run logs are stored
  report_dir: ./reports        # where HTML/PDF reports go
  keep_last_n_runs: 20         # auto-cleanup older runs

# ----- Claude AI Analysis -----
claude:
  # API key is read from ANTHROPIC_API_KEY env var (not here, for security)
  model: "claude-opus-4-7"     # or claude-sonnet-4-6 for cheaper runs
  max_tokens: 4000
  prompt_template: prompts/wifi_triage.md

  # Privacy: strip these patterns from logs before sending to Claude
  redact_patterns:
    - mac_address              # AA:BB:CC:DD:EE:FF -> [MAC]
    - ipv4_private             # keep but could mask if needed
    - serial_number            # S/N:XXXX -> [SN]

# ----- Optional: PDU for remote power cycling -----
# pdu:
#   host: 192.168.99.50
#   api_token: "CHANGEME"
#   dut_outlet: 1
